{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "拾音",
  "version": "0.1.0",
  "identifier": "com.shiyin.music",
  "build": {
    "beforeDevCommand": "npm run dev --prefix /home/zty/rust-music/apps/rustplayer-tauri/frontend",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build --prefix /home/zty/rust-music/apps/rustplayer-tauri/frontend",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "拾音",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https://*.music.126.net https://*.gtimg.cn https://*.qq.com http://*.music.126.net data:; connect-src ipc: http://localhost:* ws://localhost:*"
    }
  },
  "plugins": {}
}
